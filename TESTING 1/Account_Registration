import csv

def Registration(Reg_username, Reg_password):
    account_data = (Reg_username, Reg_password)

    with open('Accounts_data.csv', 'a', newline='') as f:
        csv_write = csv.writer(f)
        csv_write.writerow(account_data)

def Register():
    username = input('Username: ')
    password = input('Password: ')
    return username, password

data = Register()
Registration(data[0], data[1])