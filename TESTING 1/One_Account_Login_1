def interface():
    print("\n===================")
    print("One Account Login 🔐")
    print("===================\n")
    print("1) Login")
    print("2) Register")
    print("3) Quit\n")

import csv
from colorama import Fore, Style, init
init(autoreset=True)

# Registration function NEW

def Registration(Reg_username, Reg_password):
    account_data = (Reg_username, Reg_password)

    with open('Accounts_data.csv', 'a', newline='') as f:
        csv_write = csv.writer(f)
        csv_write.writerow(account_data)
        print(Fore.GREEN + '\nRegistration successful.\nPlease proceed to login.')
        interface()
        option_select()

def Register():
    username = input('Username: ')
    password = input('Password: ')
    return Registration(username, password)

# Login function NEW

attempts = 0
max_attempts = 3

def Login(username, password):
    try:
        with open('Accounts_data.csv', 'r', encoding='utf8') as file:
            csv_reader = csv.reader(file)
            next(csv_reader) # Skip the header row
            
            for row in csv_reader:
                un = str(row[0])
                pw = str(row[1])
                if username == un and password == pw:
                    print(Fore.GREEN + '\nLogin successful.')
                    return True
            else:
                print(Fore.RED + '\nLogin failed. Incorrect username or password.')
                global attempts
                attempts += 1
                if attempts >= max_attempts:
                    print(Fore.RED + '\nWarning: Too many failed attempts. Please try again later.')
                    quit()
                return user_login()

    except FileNotFoundError:
        print(Fore.RED + '\nFile not found. Perhaps create a new one?')

def user_login():
    username = input('\nUsername: ')
    password = input('Password: ')
    return Login(username, password)

# Option selection

def option_select():
    while True:
        try:
            user_input = int(input("Please select an option: \n"))
        except ValueError:
            print(Fore.RED + "\nInvalid input. Please enter a number corresponding to the options.")
        
        if user_input == 1:
            user_login()
            break
        elif user_input == 2:
            Register()
            break
        elif user_input == 3:
            print(Fore.GREEN + "Thank you for using! See you next time!")
            quit()
        else:
            print(Fore.RED + "Please select a valid option.")

interface()
option_select()
