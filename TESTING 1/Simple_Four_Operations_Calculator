#This part asks the user to input needed variables.

def Calculator():
    First_no = input("Please input your fist number: ")
    operation = input("Please select an operation [Sum, Difference, Product, Division]: ").lower()
    Second_no = input("Please input your second number: ")

#This part validates whether the inputs that are in the variables are integer except for the "operation" variable.

    try:
        VFN = int(First_no)
        VSN = int(Second_no)
    except ValueError:
        print("Please input an Integer")

#After validation, the variables are defined again and will go to the next step.

    VFN = int(First_no)
    VSN = int(Second_no)

#This part will select and print the results according to the "operation" variable.

    if operation == "sum" or operation == "+":
        Result_1 = int(VFN) + int(VSN)
        print(Result_1)
    elif operation == "difference" or operation == "-":
        Result_2 = int(VFN) - int(VSN)
        print(Result_2)
    elif operation == "product" or operation == "*":
        Result_3 = int(VFN) * int(VSN)
        print(Result_3)
    elif operation == "division" or operation == "/":
        Result_4 = int(VFN) / int(VSN)
        print(Result_4)
    else:
        print("Please make sure the operation is right.")
    
Calculator()

while True:
    re_use = input("Use again (y/n): ")
    if re_use == "y" or re_use == "Y":
        Calculator()
    else:
        print("Thank you for using! See you next time!")
        break